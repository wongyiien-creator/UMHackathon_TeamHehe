<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UMHackathon">
        <activity
            android:name=".controller.welcomePageController"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.UMHackathon">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".controller.analysisController"
            android:exported="true" />
        <activity
            android:name=".controller.comparisonController"
            android:exported="true" />
        <activity
            android:name=".controller.comparisonInputController"
            android:exported="true" />
        <activity
            android:name=".controller.homePageController"
            android:exported="true" />
        <activity
            android:name=".controller.loginPageController"
            android:exported="true" />
        <activity
            android:name=".controller.signupPageController"
            android:exported="true" />
        <activity
            android:name=".controller.saveDataController"
            android:exported="true" />

    </application>
</manifest>